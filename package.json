{
  "name": "pervigil",
  "version": "0.6.0",
  "description": "Cross-platform keep-awake / prevent-sleep utility for Node — inhibits host & display sleep (caffeinate / systemd-inhibit / SetThreadExecutionState). Zero dependencies, no native addons.",
  "keywords": [
    "keep-awake",
    "prevent-sleep",
    "wake-lock",
    "stay-awake",
    "nosleep",
    "display-sleep",
    "power-management",
    "powersaveblocker",
    "caffeinate",
    "systemd-inhibit",
    "inhibit",
    "cross-platform",
    "macos",
    "linux",
    "windows",
    "presentation"
  ],
  "license": "MIT",
  "author": "Oleksandr Zhuravlov",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    },
    "./metrics": {
      "import": {
        "types": "./dist/metrics.d.ts",
        "default": "./dist/metrics.js"
      },
      "require": {
        "types": "./dist/metrics.d.cts",
        "default": "./dist/metrics.cjs"
      }
    },
    "./supervisor": {
      "import": {
        "types": "./dist/supervisor.d.ts",
        "default": "./dist/supervisor.js"
      },
      "require": {
        "types": "./dist/supervisor.d.cts",
        "default": "./dist/supervisor.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "./dist/testing.d.ts"
      ],
      "metrics": [
        "./dist/metrics.d.ts"
      ],
      "supervisor": [
        "./dist/supervisor.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rejifald/pervigil.git"
  },
  "bugs": {
    "url": "https://github.com/rejifald/pervigil/issues"
  },
  "homepage": "https://github.com/rejifald/pervigil#readme",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  },
  "packageManager": "pnpm@10.33.2"
}
